<?xml version="1.0" encoding="utf-8"?>
<!--
  Copy this file to secrets.xml (same folder) and fill in real values.
  secrets.xml is gitignored — never commit it.

  How to get these values:
  1. GOOGLE_WEB_CLIENT_ID:
     - Go to console.cloud.google.com
     - Create a project (or use existing)
     - Enable: Google Drive API, Google Docs API, Cloud Text-to-Speech API
     - Credentials → Create OAuth 2.0 Client ID → Web Application
     - Copy the Client ID here
     - Also register an Android client ID with your app's SHA-1 fingerprint

  2. GOOGLE_CLOUD_TTS_API_KEY:
     - In the same Google Cloud project
     - Credentials → Create API Key
     - Restrict it to Cloud Text-to-Speech API only
-->
<resources>
    <string name="google_web_client_id">YOUR_WEB_CLIENT_ID_HERE.apps.googleusercontent.com</string>
    <string name="google_cloud_tts_api_key">YOUR_TTS_API_KEY_HERE</string>
</resources>
